simulator/satellite_ground.jpg

# Isaac Sim generated files
simulator/geo_metadata.json
simulator/*.log
simulator/__pycache__/

# Drone camera live output (transient — overwritten every 5 sim steps)
simulator/drone_frames/

# AnyLoc generated database (rebuild with: python anyloc/build_database.py --rebuild)
anyloc/database/

# AnyLoc test / debug output
anyloc/test_output/

# Claude Code local settings
**/.claude/

# Model weights (large files — store in DVC or separate release)
**/*.pt
**/*.pth
**/*.onnx
**/*.weights
**/*.engine

# Dataset files
**/*.bag
**/dataset/
**/data/

# ArduPilot SITL runtime artefacts (written to project root by sim_vehicle.py)
eeprom.bin
mav.tlog
mav.tlog.raw
*.tlog
*.tlog.raw
*.bin
*.parm
!control/no_gps.parm
terrain/

# AnyLoc runtime output (written each anchor frame, read by run_vision.py)
anyloc/latest_estimate.json

# Terrain elevation written by cesium_scene.py on startup (runtime, machine-specific)
control/home_elevation.json

# ArduPilot SITL logs (written to project root and control/ by sim_vehicle.py)
logs/
control/logs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

