env/

# Simulator caches (large binary/tile data — re-downloadable)
simulator/cesium_tile_cache/
simulator/cesium_terrain_cache/
simulator/cesium_tile_list.json
simulator/cesium_terrain_list.json
simulator/elevation_cache.json
